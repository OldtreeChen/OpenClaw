{
  "name": "openclaw-restaurant-bot",
  "version": "0.1.0",
  "description": "Restaurant search and reservation assistant powered by the OpenAI Responses API.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "postinstall": "node scripts/install-playwright.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test \"tests/*.test.js\"",
    "docs:generate": "node scripts/generate-docs.js",
    "ci:check": "npm run test && npm run docs:generate",
    "test:site": "node scripts/run-site-test.js",
    "report:service-request": "node scripts/generate-service-request-word-report.js"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "openai": "^6.6.0",
    "playwright": "^1.54.2"
  }
}
